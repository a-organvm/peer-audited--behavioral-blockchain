{
  "name": "StyxMobile",
  "displayName": "Styx",
  "expo": {
    "name": "Styx",
    "slug": "styx-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "styx",
    "newArchEnabled": true,
    "android": {
      "package": "com.styxprotocol.app"
    },
    "ios": {
      "bundleIdentifier": "com.styxprotocol.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Styx needs camera access to capture proof submissions for behavioral contract verification.",
        "NSPhotoLibraryUsageDescription": "Styx needs photo library access to select proof images for contract verification."
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ff4444",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
